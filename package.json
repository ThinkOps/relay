    "test": "node --no-warnings --test test/*.test.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ThinkOps/relay.git"
  },
  "bugs": {
    "url": "https://github.com/ThinkOps/relay/issues"
  },
  "homepage": "https://github.com/ThinkOps/relay#readme",
  "keywords": [
    "agent",
    "kanban",
    "project-management",
    "cli",
    "sqlite"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "UNLICENSED"
