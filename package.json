{
  "name": "@thinkops/relay",
  "version": "0.1.2",
  "description": "Admin-first project board for managing agent work.",
  "type": "commonjs",
  "bin": {
    "relay": "./bin/relay.js"
  },
  "files": [
    "bin",
    "docs",
    "src",
    "web",
    "README.md"
  ],
  "scripts": {
    "coverage": "node --no-warnings --experimental-test-coverage --test test/*.test.js",
